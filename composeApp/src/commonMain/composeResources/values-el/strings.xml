    <string name="settings_daemon_mode">Λειτουργία Daemon</string>
    <string name="settings_daemon_mode_description">Διατηρήστε το Hyper-Claw σε λειτουργία στο παρασκήνιο ώστε οι προγραμματισμένες εργασίες να εκτελούνται ακόμα και όταν η εφαρμογή δεν είναι στο προσκήνιο.</string>
